# =============================================================================
# dm-ringbox 驱动 Makefile
# =============================================================================
# 功能说明：
#   - 支持交叉编译，目标平台为 ARM64 (RK3568/RK3588)
#   - 编译产物统一输出到项目根目录的 build/ 文件夹
#   - 支持模块安装和清理操作
#
# 目录结构：
#   dm-ringbox/
#   ├── include/
#   │   └── dm-ringbox.h    # 头文件
#   ├── src/
#   │   └── dm-ringbox.c    # 源文件
#   ├── Makefile
#   └── README.md
#
# 使用方法：
#   make              - 编译驱动模块
#   make install      - 安装模块到 build 目录
#   make clean        - 清理编译产物
#
# @author RK3568 Development Team
# @version 1.0.0
# @date 2026-04-15
# =============================================================================

# -----------------------------------------------------------------------------
# SDK 路径配置
# 根据实际开发环境修改以下路径
# -----------------------------------------------------------------------------
SDK_PATH ?= /home/topeet/Linux_SDK/rk3568_linux_5.10
KDIR := $(SDK_PATH)/kernel

# -----------------------------------------------------------------------------
# 交叉编译器配置
# 使用 RK3568 SDK 自带的 ARM64 交叉编译器
# -----------------------------------------------------------------------------
CROSS_COMPILE := $(SDK_PATH)/prebuilts/gcc/linux-x86/aarch64/gcc-arm-10.3-2021.07-x86_64-aarch64-none-linux-gnu/bin/aarch64-none-linux-gnu-

# -----------------------------------------------------------------------------
# 目标架构配置
# -----------------------------------------------------------------------------
ARCH := arm64

# -----------------------------------------------------------------------------
# 模块定义
# -----------------------------------------------------------------------------
obj-m += dm-ringbox.o

# 源文件路径
dm-ringbox-y := src/dm-ringbox.o

# -----------------------------------------------------------------------------
# 项目根目录（用于定位 build/ 输出目录）
# -----------------------------------------------------------------------------
PROJECT_ROOT := $(abspath $(CURDIR)/../../..)
BUILD_DIR := $(PROJECT_ROOT)/build/drivers/dm-ringbox

# -----------------------------------------------------------------------------
# 头文件路径
# -----------------------------------------------------------------------------
EXTRA_CFLAGS += -I$(CURDIR)/include

# -----------------------------------------------------------------------------
# 编译目标
# -----------------------------------------------------------------------------
.PHONY: all clean install help

all: modules
	@echo "=========================================="
	@echo "[INFO] 编译完成!"
	@echo "[INFO] 目标平台: $(ARCH)"
	@echo "[INFO] 内核源码: $(KDIR)"
	@echo "=========================================="

modules:
	@echo "[INFO] 开始编译 dm-ringbox 驱动..."
	$(MAKE) -C $(KDIR) M=$(CURDIR) ARCH=$(ARCH) CROSS_COMPILE=$(CROSS_COMPILE) modules

# -----------------------------------------------------------------------------
# 安装目标 - 将编译产物复制到 build 目录
# -----------------------------------------------------------------------------
install: all
	@echo "[INFO] 安装驱动模块到 build 目录..."
	@mkdir -p $(BUILD_DIR)/include
	@mkdir -p $(BUILD_DIR)/modules
	@cp -v *.ko $(BUILD_DIR)/modules/
	@cp -v Module.symvers $(BUILD_DIR)/modules/ 2>/dev/null || true
	@cp -v include/dm-ringbox.h $(BUILD_DIR)/include/
	@echo "=========================================="
	@echo "[INFO] 驱动已安装到: $(BUILD_DIR)"
	@echo "=========================================="
	@ls -lh $(BUILD_DIR)/modules/*.ko 2>/dev/null || echo "[WARN] 未找到 .ko 文件"

# -----------------------------------------------------------------------------
# 清理目标
# -----------------------------------------------------------------------------
clean:
	@echo "[INFO] 清理编译产物..."
	$(MAKE) -C $(KDIR) M=$(CURDIR) ARCH=$(ARCH) clean
	@rm -rf $(BUILD_DIR)
	@rm -f Module.symvers modules.order
	@rm -f src/*.o 2>/dev/null || true
	@echo "[INFO] 清理完成"

# -----------------------------------------------------------------------------
# 帮助信息
# -----------------------------------------------------------------------------
help:
	@echo "dm-ringbox 驱动编译系统"
	@echo ""
	@echo "目录结构:"
	@echo "  include/     - 头文件目录"
	@echo "  src/         - 源文件目录"
	@echo ""
	@echo "可用目标:"
	@echo "  make          - 编译驱动模块"
	@echo "  make install  - 安装模块到 build/ 目录"
	@echo "  make clean    - 清理编译产物"
	@echo "  make help     - 显示此帮助信息"
	@echo ""
	@echo "配置变量:"
	@echo "  SDK_PATH      - SDK 安装路径 (当前: $(SDK_PATH))"
	@echo "  KDIR          - 内核源码路径 (当前: $(KDIR))"
	@echo "  ARCH          - 目标架构 (当前: $(ARCH))"
	@echo ""
	@echo "示例:"
	@echo "  make SDK_PATH=/path/to/sdk"
